FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PATH="/opt/venv/bin:${PATH}"
ENV UV_PROJECT_ENVIRONMENT="/opt/venv"

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates xvfb xauth \
    && rm -rf /var/lib/apt/lists/*

RUN python -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir uv

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --group image-worker --no-install-project

RUN playwright install --with-deps chromium

COPY app app
COPY workers workers

CMD ["/bin/sh", "-lc", "Xvfb :99 -screen 0 1440x960x24 -nolisten tcp & export DISPLAY=:99 && exec /opt/venv/bin/uvicorn workers.chatgpt_image_worker.app:app --host 0.0.0.0 --port 3091"]
